datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum DocumentKind {
  BLOG
  PROJECT
}

enum DocumentStatus {
  DRAFT
  PUBLISHED
}

model Document {
  id               String         @id @default(dbgenerated("gen_random_uuid()::text"))
  ownerId          String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt
  kind             DocumentKind?
  status           DocumentStatus @default(DRAFT)
  slug             String?
  excerpt          String?
  publishedAt      DateTime?

  latestRevisionId String?         @unique
  latestRevision   Revision?       @relation("LatestRevision", fields: [id, latestRevisionId], references: [documentId, id])

  revisions        Revision[]      @relation("DocumentRevisions")

  @@index([ownerId])
  @@index([status, kind, publishedAt])
  @@unique([id, latestRevisionId])
}

model Revision {
  id             String    @id @default(dbgenerated("gen_random_uuid()::text"))
  documentId     String
  createdAt      DateTime  @default(now())
  revisionNumber Int
  title          String
  content        String
  createdBy      String

  document       Document  @relation("DocumentRevisions", fields: [documentId], references: [id], onDelete: Cascade)
  latestOf       Document? @relation("LatestRevision")

  @@unique([documentId, id])
  @@unique([documentId, revisionNumber])
  @@index([documentId, createdAt])
}
